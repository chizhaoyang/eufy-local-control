# Use a dedicated guest Eufy account shared to the devices, not the owner account.
EUFY_USERNAME=you@example.com
EUFY_PASSWORD=change-me
# Must match the country selected in the Eufy Security app.
EUFY_COUNTRY=US
# "quickest" prefers whichever P2P path works; use "local-only" to forbid relay fallback.
EUFY_P2P_MODE=quickest
# Required by some P2P cameras on newer Node.js 20/22 releases.
EUFY_EMBEDDED_PKCS1=true

# Keep this on 127.0.0.1 unless you add HTTPS and authentication in front of it.
HOST=127.0.0.1
PORT=3000
RECORDINGS_DIR=./recordings
EUFY_DATA_DIR=./.eufy
# 0 disables the eufy-security-client's automatic livestream time limit.
STREAM_MAX_SECONDS=0
